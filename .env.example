# Скопируйте в .env. Секреты не коммитьте. Шаблон совпадает с полями packages/shared/settings.py.

# --- MAX (staging / production) ---
# MAX_API_BASE=https://platform-api.max.ru
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
MAX_OUTBOUND_ENABLED=true
M6_REQUIRE_MAX_TOKEN_IF_OUTBOUND=true

# --- База: для staging/production — Postgres (Supabase и т.д.), asyncpg ---
# Пример Supabase: postgresql+asyncpg://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
# Локально без Docker: можно sqlite+aiosqlite:///./finalmaxbot.db

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=

# --- YandexGPT / Foundation Models (опционально) ---
YANDEX_CLOUD_API_KEY=
YANDEX_FOLDER_ID=
# YANDEX_MODEL_URI=gpt://<folder_id>/yandexgpt/latest
# YANDEX_COMPLETION_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion

# --- M4: квоты (опционально) ---
# M4_CONSUMER_FREE_IMAGES_PER_ROLLING_24H=3
# M4_CONSUMER_FREE_TEXT_CHATS_PER_ROLLING_24H=15
# M4_CONSUMER_PLUS_MAX_IMAGES_PER_MONTH=120
# M4_CONSUMER_PLUS_TEXT_CHATS_PER_ROLLING_24H=100
# M4_BUSINESS_FREE_IMAGES_PER_ROLLING_24H=3
# M4_BUSINESS_FREE_TEXT_CHATS_PER_ROLLING_24H=20
# M4_BUSINESS_MARKETER_MAX_IMAGES_PER_MONTH=120
# M4_BUSINESS_MARKETER_MAX_VK_POSTS_PER_MONTH=30
# M4_BUSINESS_MARKETER_TEXT_CHATS_PER_ROLLING_24H=100

# --- M5: файлы и водяной знак ---
# Локально: ./data/generated | в Docker с томом: /data/generated (см. docs/docker.md)
# M5_LOCAL_STORAGE_ROOT=./data/generated
# M5_WATERMARK_TEXT=Free
# M5_WATERMARK_OPACITY=0.35
# M5_MAX_UPLOAD_READY_DELAY_SEC=0.75
# M5_MAX_SEND_ATTACHMENT_RETRIES=5
# YANDEX_IMAGE_GENERATION_ENABLED=false
# YANDEX_IMAGE_MODEL_URI=art://<folder_id>/yandex-art/latest
# YANDEX_IMAGE_ASYNC_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/imageGenerationAsync
# YANDEX_IMAGE_OPERATIONS_URL_TEMPLATE=https://llm.api.cloud.yandex.net/operations/{operation_id}
# YANDEX_IMAGE_POLL_INTERVAL_SEC=2.0
# YANDEX_IMAGE_POLL_TIMEOUT_SEC=120.0

# --- M6 / Т-Банк (пустые TERMINAL_KEY и PASSWORD = stub-оплата) ---
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
# TBANK_API_BASE=https://securepay.tinkoff.ru/v2
# Публичный HTTPS вашего API: POST уведомлений (как в кабинете Т-Банка)
TBANK_NOTIFICATION_URL=
# TBANK_SUCCESS_URL=https://your-frontend.example/paid
# TBANK_PAYMENT_DESCRIPTION_PREFIX=finalmaxbot:
# Только отладка; в production = false
TBANK_SKIP_SIGNATURE_VERIFY=false
M6_SUBSCRIPTION_PERIOD_DAYS=30

# --- M7: рекуррент ---
M7_RECURRING_ENABLED=true
M7_RENEWAL_ADVANCE_HOURS=36

# --- Схема БД и внутренние эндпоинты ---
RUN_ALEMBIC_ON_STARTUP=true
ALLOW_RUNTIME_CREATE_ALL=false
# Один ключ для /internal/m4, /internal/m7, /internal/launch (пусто = 404)
INTERNAL_DEBUG_KEY=

# Ожидание TCP БД в Docker entrypoint (сек)
# DB_WAIT_TIMEOUT_SEC=90
