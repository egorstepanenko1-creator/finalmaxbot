# Скопируйте в .env и заполните. Не коммитьте .env и не вставляйте секреты в .env.example.

# Google AI Studio (Gemini API): https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Supabase: Project Settings → API (для будущих клиентских интеграций)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# MAX Bot API: https://dev.max.ru/docs-api
MAX_BOT_TOKEN=
# Секрет webhook (заголовок X-Max-Bot-Api-Secret), опционально
MAX_WEBHOOK_SECRET=

# Postgres: Supabase → Project Settings → Database → Connection string (URI).
# Прямой хост db.<ref>.supabase.co часто только IPv6; на Windows без IPv6
# возьмите строку «Session pooler» / IPv4 из того же экрана и вставьте сюда.
# Для asyncpg к URI обычно добавляют SSL, например: ?ssl=require
DATABASE_URL=sqlite+aiosqlite:///./finalmaxbot.db

MAX_OUTBOUND_ENABLED=true

