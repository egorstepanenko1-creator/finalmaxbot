# Скопируйте в .env. Секреты не храните в .env.example (файл в Git).

GOOGLE_AI_API_KEY=

# Yandex Foundation Models / YandexGPT (опционально)
YANDEX_CLOUD_API_KEY=
YANDEX_FOLDER_ID=
# YANDEX_MODEL_URI=gpt://<folder_id>/yandexgpt/latest

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=

MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=

DATABASE_URL=sqlite+aiosqlite:///./finalmaxbot.db

MAX_OUTBOUND_ENABLED=true
# Если true и outbound включён, без токена в лог пишется предупреждение при старте
M6_REQUIRE_MAX_TOKEN_IF_OUTBOUND=true

# M6 / Т-Банк (пусто = stub-оплата для разработки)
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
# TBANK_API_BASE=https://securepay.tinkoff.ru/v2
# Публичный HTTPS URL, который Т-Банк вызовет POST (как в личном кабинете / Init)
TBANK_NOTIFICATION_URL=
# TBANK_SUCCESS_URL=https://your-frontend.example/paid
# TBANK_PAYMENT_DESCRIPTION_PREFIX=finalmaxbot:
# Только локальная отладка; в production должно быть false
TBANK_SKIP_SIGNATURE_VERIFY=false
M6_SUBSCRIPTION_PERIOD_DAYS=30

# M4: миграции Alembic при старте API (true по умолчанию)
RUN_ALEMBIC_ON_STARTUP=true
# Только для локалки: создать недостающие таблицы через SQLAlchemy create_all
ALLOW_RUNTIME_CREATE_ALL=false
# Ключ для GET/POST /internal/m4/* (пусто = эндпоинты отвечают 404)
INTERNAL_DEBUG_KEY=

# Лимиты M4 (опционально; см. packages/shared/settings.py)
# M4_CONSUMER_FREE_IMAGES_PER_ROLLING_24H=3
# M4_CONSUMER_FREE_TEXT_CHATS_PER_ROLLING_24H=15

# M5: файлы и водяной знак
# M5_LOCAL_STORAGE_ROOT=./data/generated
# M5_WATERMARK_TEXT=Free
# M5_WATERMARK_OPACITY=0.35
# YANDEX_IMAGE_GENERATION_ENABLED=false
# YANDEX_IMAGE_MODEL_URI=art://<folder_id>/yandex-art/latest
# YANDEX_IMAGE_ASYNC_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/imageGenerationAsync
# YANDEX_IMAGE_OPERATIONS_URL_TEMPLATE=https://llm.api.cloud.yandex.net/operations/{operation_id}
