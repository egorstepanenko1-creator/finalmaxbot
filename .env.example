# Скопируйте в .env и заполните. Файл .env не коммитится.

# Google AI Studio (Gemini API): https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Идентификатор ключа в консоли (для справки в логах/документации, опционально)
# GOOGLE_AI_API_KEY_ID=

# Supabase: Project Settings → API
SUPABASE_URL=https://epsmhvhllhbcfiddtdlh.supabase.co
SUPABASE_ANON_KEY=
# Для серверных сценариев (не в клиенте): SUPABASE_SERVICE_ROLE_KEY=

# MAX Bot API: https://dev.max.ru/docs-api
MAX_BOT_TOKEN=
# Секрет из подписки webhook (заголовок X-Max-Bot-Api-Secret), опционально
MAX_WEBHOOK_SECRET=
# Локально: sqlite+aiosqlite:///./finalmaxbot.db
# Supabase (Settings → Database → URI, async): postgresql://... → подставьте в DATABASE_URL
DATABASE_URL=sqlite+aiosqlite:///./finalmaxbot.db
# Без токена исходящие вызовы только в лог (true = звонить в platform-api при наличии токена)
MAX_OUTBOUND_ENABLED=true

