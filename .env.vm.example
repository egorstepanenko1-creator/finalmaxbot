# Скопируйте на VM как /opt/finalmaxbot/.env и заполните секреты.
# Запуск: docker compose -f docker-compose.yml -f docker-compose.vm-sqlite.yml up --build -d

MAX_MODE=polling
MAX_AUTO_REGISTER_WEBHOOK=false
MAX_OUTBOUND_ENABLED=true

DATABASE_URL=sqlite+aiosqlite:////data/db/finalmaxbot.db
RUN_ALEMBIC_ON_STARTUP=true
ALLOW_RUNTIME_CREATE_ALL=false

MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=

# Внутренние эндпоинты (не публикуйте ключ); для smoke аналитики:
INTERNAL_DEBUG_KEY=

# Yandex текст (опционально)
YANDEX_CLOUD_API_KEY=
YANDEX_FOLDER_ID=

# Yandex картинки (опционально)
YANDEX_IMAGE_GENERATION_ENABLED=false
YANDEX_IMAGE_MODEL_URI=

M5_LOCAL_STORAGE_ROOT=/data/generated

# Логи docker: docker compose logs -f app
APP_PORT=8000
